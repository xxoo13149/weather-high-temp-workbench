{
  "name": "meteoblue-weather-relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:web": "npm --prefix zip run dev",
    "dev:cloudflare": "npx wrangler dev",
    "stitch:explore": "node tools/stitch-concept.mjs explore",
    "stitch:refine": "node tools/stitch-concept.mjs refine",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.build.json",
    "build:web": "npm --prefix zip run build",
    "check:encoding": "node tools/check-encoding.mjs",
    "check": "tsc --noEmit && npm --prefix zip run lint && node tools/check-encoding.mjs",
    "start": "node dist/index.js",
    "deploy:cloudflare": "npx wrangler deploy",
    "audit:production": "node tools/audit-production-city-health.mjs",
    "test": "vitest run",
    "test:pw": "node tools/playwright-location-regression.cjs",
    "test:pw:online": "node tools/playwright-location-regression.cjs --suite=online-smoke"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "cheerio": "^1.1.2",
    "fastify": "^5.3.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@google/stitch-sdk": "^0.1.0",
    "@types/node": "^24.5.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
